                <mxCell id="118" value="&lt;h1 style=&quot;margin-top: 0px; line-height: 90%;&quot;&gt;&lt;span style=&quot;background-color: transparent; font-weight: normal;&quot;&gt;Why Vheexa?&lt;/span&gt;&lt;/h1&gt;&lt;div style=&quot;line-height: 90%;&quot;&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; font-size: 18px; line-height: 90%;&quot;&gt;To Enhance My Developement Skills.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 18px; background-color: transparent;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;line-height: 150%;&quot;&gt;&lt;font style=&quot;font-size: 24px; line-height: 150%;&quot;&gt;Who Want to Use Vheexa?&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;line-height: 150%;&quot;&gt;&lt;span style=&quot;font-size: 18px; line-height: 150%;&quot;&gt;Clients: Who Want to Rent Vehicles.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;span style=&quot;&quot;&gt;Individuals and Companies: Who Want to Rent Their Vehicles.&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;span style=&quot;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;line-height: 150%;&quot;&gt;&lt;font style=&quot;font-size: 24px; line-height: 150%;&quot;&gt;&lt;span&gt;What Does Vheexa Do?&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;line-height: 150%;&quot;&gt;&lt;span style=&quot;font-size: 18px; text-wrap-mode: nowrap; line-height: 150%;&quot;&gt;Making Renting Process Easier for Both Clients, Individual and Companies&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 24px; background-color: transparent;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 24px; background-color: transparent;&quot;&gt;Features&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;line-height: 150%;&quot;&gt;&lt;span style=&quot;font-size: 18px; text-wrap-mode: nowra