            },
            {
              "id": "faq-insurance",
              "question": "هل الأسعار شاملة للتأمين؟",
              "answer": "تتضمن معظم المركبات تأمينًا أساسيًا، كما يمكنك إضافة خيارات تأمين إضافية عند إتمام الحجز."
            },
